FROM lucee/lucee:6.0

# Java security config for SQL Server SHA1 cert compatibility
COPY deploy/swarm/custom.java.security /tmp/custom.java.security
RUN JAVA_SECURITY=$(find / -name "java.security" -path "*/conf/security/*" 2>/dev/null | head -1) && \
    if [ -n "$JAVA_SECURITY" ]; then \
        echo "" >> "$JAVA_SECURITY" && \
        echo "# Custom overrides for SQL Server SHA1 cert compatibility" >> "$JAVA_SECURITY" && \
        cat /tmp/custom.java.security >> "$JAVA_SECURITY"; \
    fi && rm -f /tmp/custom.java.security

# Copy full application (ForgeBox dependencies resolved in CI via box install)
COPY . /app/

# Set up URL rewriting: copy default WEB-INF (contains Tuckey filter config)
# into our webroot and add our rewrite rules
RUN cp -r /var/www/WEB-INF /app/public/WEB-INF && \
    cp /app/public/urlrewrite.xml /app/public/WEB-INF/urlrewrite.xml

# Point Tomcat docbase to our public directory
RUN sed -i 's|docBase="/var/www"|docBase="/app/public"|g' /usr/local/tomcat/conf/server.xml
