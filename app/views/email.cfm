    <body>
        <cfoutput>
            <div class="content">
                <img src="data:image/png;base64," alt="Logo" width="260">
                <h1 class="mt-4">Welcome to Wheels.dev!</h1>
                <h1 class="mt-4">Dear #params.name#</h1>
                <p class="mb-4">#params.content#</p>
                <cfif params.URl neq "">
                    <a href="#params.URl#" class="text-white fw-medium px-5 py-2 fs-12 rounded-2 bg--primary w-100"> #params.buttonTitle# </a>
                </cfif>
                <p class="footer">#params.footer#</p>
            </div>
        </cfoutput>
